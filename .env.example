# Set true to use the built-in fictional demo data without a backend.
VITE_DEMO_MODE=true

# Public browser credentials. Security depends on Supabase RLS, not secrecy here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Static site base path. GitHub Pages uses "/teaching-loop-platform/".
VITE_BASE_PATH=/

# Local tools only. Keep these in .env.local and never commit them.
PLATFORM_URL=
KNOWLEDGE_SYNC_TOKEN=
TEACHER_ACCESS_TOKEN=

# AI_* values are server-only Supabase Edge Function secrets. Do not put them in
# this frontend .env file; see docs/free-deployment.md and docs/deployment.md.
