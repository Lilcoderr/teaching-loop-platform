# Copy to a private server-only env file. Never commit real values.

POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-at-least-32-characters
ANON_KEY=replace-with-generated-anon-jwt
SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt

SITE_URL=https://app.example.com
API_EXTERNAL_URL=https://api.example.com
STUDIO_DEFAULT_ORGANIZATION=Teaching Loop
STUDIO_DEFAULT_PROJECT=Teaching Loop Platform

ALLOWED_ORIGINS=https://app.example.com

# Optional AI provider. Leave blank to keep AI features disabled.
AI_BASE_URL=
AI_API_KEY=
AI_TEXT_MODEL=
AI_VISION_MODEL=
AI_EMBEDDING_MODEL=
